{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Bash(npx astro:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/stop-hook.mjs",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
