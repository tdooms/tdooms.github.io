---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import { formatDate } from '../lib/format'

interface Props {
  title: string
  date: string
  link: string
  image?: ImageMetadata | undefined
  external?: boolean | undefined
}

const { title, date, link, image, external = false } = Astro.props

const formattedDate = formatDate(date)
---

<a
  href={link}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="card card-border group bg-base-100 border-base-300/60 h-full overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
>
  {
    image && (
      <figure class="bg-base-200 relative aspect-[5/3] overflow-hidden">
        {/* Sized to the card (≈350px wide, 2× for retina) — `layout="none"`
            here once shipped the full 1254px originals (90–240 KB each) and
            blew the home page's Lighthouse LCP budget. q60 because card art
            renders desaturated at ~350px; the savings buy LCP headroom. */}
        <Image
          src={image}
          alt={title}
          layout="none"
          width={700}
          height={420}
          quality={60}
          class="absolute inset-0 h-full w-full transform-gpu object-cover saturate-50 transition-[filter] duration-300 ease-out [backface-visibility:hidden] group-hover:saturate-100"
        />
      </figure>
    )
  }
  <div class="card-body flex-1 gap-2 p-4">
    <div class="flex items-center justify-between gap-3">
      <time class="text-base-content/70 text-xs font-semibold tracking-wider uppercase">
        {formattedDate}
      </time>
      {
        external && (
          <Icon name="fa6-solid:arrow-up-right-from-square" class="text-base-content/65 text-xs" />
        )
      }
    </div>
    <h3 class="card-title text-base">{title}</h3>
  </div>
</a>
