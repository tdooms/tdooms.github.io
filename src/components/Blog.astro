---
import { Image } from 'astro:assets';

interface Props {
	title: string;
	date: string;
	image: ImageMetadata;
	link: string;
	external?: boolean;
}

const { title, date, image, link, external = false } = Astro.props;

// Format date nicely
const formattedDate = new Date(date).toLocaleDateString('en-GB', { 
	day: 'numeric', 
	month: 'short', 
	year: 'numeric' 
});
---

<a href={link} target={external ? '_blank' : '_self'} class="block">
	<div class="card bg-white shadow-md hover:shadow-xl transition-all duration-300 hover:scale-[1.02]">
		<figure class="overflow-hidden relative">
			<Image
				src={image}
				alt={title}
				class="w-full h-48 object-cover grayscale-[0.75] hover:grayscale-0 transition-all duration-300"
			/>
			{external && (
				<div class="absolute bottom-2 right-2 bg-white/80 backdrop-blur-sm rounded-full w-8 h-8 flex items-center justify-center shadow-sm">
					<i class="fa-solid fa-arrow-up-right-from-square text-sm text-gray-600"></i>
				</div>
			)}
		</figure>
		<div class="card-body p-6">
			<h4 class="card-title text-xl text-gray-900">{title}</h4>
			<div class="text-gray-600 text-sm">{formattedDate}</div>
		</div>
	</div>
</a>
