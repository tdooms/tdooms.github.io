---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  date: string
  link: string
  image?: ImageMetadata | undefined
  external?: boolean | undefined
}

const { title, date, link, image, external = false } = Astro.props

const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
})
---

<a
  href={link}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="group bg-base-100 ring-base-300/60 flex h-full flex-col overflow-hidden rounded-xl shadow-sm ring-1 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
>
  {
    image && (
      <figure class="bg-base-200 relative aspect-[5/3] overflow-hidden">
        <Image
          src={image}
          alt={title}
          layout="none"
          class="absolute inset-0 h-full w-full transform-gpu object-cover saturate-50 transition-[filter] duration-300 ease-out [backface-visibility:hidden] group-hover:saturate-100"
        />
      </figure>
    )
  }
  <div class="flex flex-1 flex-col gap-2 p-4">
    <div class="flex items-center justify-between gap-3">
      <time class="text-base-content/70 text-xs font-semibold tracking-wider uppercase">
        {formattedDate}
      </time>
      {
        external && (
          <Icon name="fa6-solid:arrow-up-right-from-square" class="text-base-content/65 text-xs" />
        )
      }
    </div>
    <h3 class="text-base-content truncate text-base font-bold">{title}</h3>
  </div>
</a>
