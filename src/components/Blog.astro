---
import { Image } from 'astro:assets'

interface Props {
  title: string
  date: string
  image: ImageMetadata
  link: string
  external?: boolean
}

const { title, date, image, link, external = false } = Astro.props

// Format date nicely
const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
})
---

<a
  href={link}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="block"
>
  <div
    class="card bg-white shadow-md transition-all duration-300 hover:scale-[1.02] hover:shadow-xl"
  >
    <figure class="relative overflow-hidden">
      <Image
        src={image}
        alt={title}
        class="h-48 w-full object-cover grayscale-[0.75] transition-all duration-300 hover:grayscale-0"
      />
      {
        external && (
          <div class="absolute right-2 bottom-2 flex h-8 w-8 items-center justify-center rounded-full bg-white/80 shadow-sm backdrop-blur-sm">
            <i class="fa-solid fa-arrow-up-right-from-square text-sm text-gray-600" />
          </div>
        )
      }
    </figure>
    <div class="card-body p-6">
      <h4 class="card-title text-xl text-gray-900">{title}</h4>
      <div class="text-sm text-gray-600">{formattedDate}</div>
    </div>
  </div>
</a>
