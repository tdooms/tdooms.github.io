---
import { Icon } from 'astro-icon/components'

interface Props {
  bib: string
}

const { bib } = Astro.props
---

<div class="card bg-base-200 hidden shadow-md md:block">
  <div class="bg-base-300 flex items-center justify-between px-4 py-2">
    <h2 class="text-base-content font-semibold">How to cite</h2>
    <button type="button" class="btn btn-ghost btn-sm cite-copy" aria-label="Copy citation">
      <Icon name="fa6-solid:copy" class="text-base" />
    </button>
  </div>
  <pre class="cite-content overflow-x-auto p-4 text-xs break-words whitespace-pre-wrap">{bib}</pre>
</div>

<script>
  // Single delegated listener for the lifetime of the document.
  // Bundled modules run once, so this binds exactly one handler regardless of
  // how many <Cite/> instances exist or how many ClientRouter navigations occur.
  document.addEventListener('click', (event) => {
    const target = event.target
    if (!(target instanceof Element)) return
    const btn = target.closest('.cite-copy')
    if (!btn) return
    const pre = btn.closest('.card')?.querySelector('.cite-content')
    if (pre?.textContent) void navigator.clipboard.writeText(pre.textContent)
  })
</script>
