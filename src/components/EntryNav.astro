---
import { Icon } from 'astro-icon/components'
import HomeIcon from './Icon.svelte'

interface NavItem {
  href: string
  title: string
}

interface Props {
  prev: NavItem | null
  next: NavItem | null
}

const { prev, next } = Astro.props
---

<nav
  class="border-base-300/60 mt-12 grid grid-cols-[1fr_auto_1fr] items-center gap-4 border-t pt-8"
>
  {
    prev ? (
      <a
        href={prev.href}
        class="group text-base-content/85 hover:text-primary flex flex-col gap-1 transition-colors"
      >
        <span class="text-base-content/65 flex items-center gap-1.5 text-xs font-semibold tracking-wider uppercase">
          <Icon
            name="fa6-solid:arrow-left"
            class="text-xs transition-transform group-hover:-translate-x-0.5"
          />
          Previous
        </span>
        <span class="font-semibold">{prev.title}</span>
      </a>
    ) : (
      <span />
    )
  }

  <a href="/" aria-label="Back to home" class="btn btn-ghost btn-square btn-sm">
    <HomeIcon name="house" class="h-4 w-4" />
  </a>

  {
    next ? (
      <a
        href={next.href}
        class="group text-base-content/85 hover:text-primary flex flex-col gap-1 text-right transition-colors"
      >
        <span class="text-base-content/65 flex items-center justify-end gap-1.5 text-xs font-semibold tracking-wider uppercase">
          Next
          <Icon
            name="fa6-solid:arrow-right"
            class="text-xs transition-transform group-hover:translate-x-0.5"
          />
        </span>
        <span class="font-semibold">{next.title}</span>
      </a>
    ) : (
      <span />
    )
  }
</nav>
