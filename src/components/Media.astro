---
import { Image } from 'astro:assets'
import { formatMonthYear } from '../lib/format'

interface Props {
  icon: ImageMetadata
  title: string
  start: string
  end?: string | undefined
  text?: string | undefined
  grade?: string | undefined
  subject?: string | undefined
  advisor?: string | undefined
}

const { icon, title, start, end, text, grade, subject, advisor } = Astro.props

const dateRange = end
  ? `${formatMonthYear(start)} — ${formatMonthYear(end)}`
  : `${formatMonthYear(start)} — TBD`
---

<div class="bg-base-100 ring-base-300/60 mb-3 rounded-xl p-5 shadow-sm ring-1">
  <div class="flex items-start gap-4">
    <figure class="h-10 w-10 shrink-0">
      <Image
        src={icon}
        alt={`${title} logo`}
        width={80}
        height={80}
        class="h-full w-full object-contain"
      />
    </figure>
    <div class="min-w-0 flex-1">
      <h5 class="text-base-content text-lg font-bold">{title}</h5>
      <p class="text-base-content/70 text-xs font-semibold tracking-wider uppercase">{dateRange}</p>
    </div>
  </div>
  {text && <p class="text-base-content/85 mt-3 text-sm">{text}</p>}
  {
    subject && (
      <p class="text-base-content/85 mt-2 text-sm">
        <span class="font-semibold">Subject:</span> {subject}
      </p>
    )
  }
  {
    advisor && (
      <p class="text-base-content/85 mt-1 text-sm">
        <span class="font-semibold">Advisor:</span> {advisor}
      </p>
    )
  }
  {
    grade && (
      <p class="text-base-content/85 mt-1 text-sm">
        <span class="font-semibold">Grade:</span> {grade}
      </p>
    )
  }
  <slot />
</div>
