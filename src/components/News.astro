---
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  date: string
  icon?: string
  link?: string
  external?: boolean
}

const { title, date, icon = 'fa6-solid:newspaper', link, external = false } = Astro.props

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
})

// Title supports **bold** markdown for emphasis (rendered in primary orange).
const renderedTitle = title.replace(
  /\*\*(.+?)\*\*/g,
  '<strong class="font-semibold text-primary">$1</strong>',
)

const Tag = link ? 'a' : 'div'
const tagProps = link
  ? {
      href: link,
      target: external ? '_blank' : undefined,
      rel: external ? 'noopener noreferrer' : undefined,
    }
  : {}
---

<Tag
  class:list={[
    'bg-base-100 ring-base-300/60 flex items-center gap-3 rounded-lg px-4 py-3 shadow-sm ring-1 transition-all duration-200',
    link && 'group hover:-translate-y-0.5 hover:shadow-md',
  ]}
  {...tagProps}
>
  <div class="bg-primary/10 flex h-9 w-9 shrink-0 items-center justify-center rounded-full">
    <Icon name={icon} class="text-primary text-sm" />
  </div>
  <div class="flex min-w-0 flex-1 items-baseline justify-between gap-3">
    <h3 class="text-base-content/85 truncate text-base" set:html={renderedTitle} />
    <time class="text-base-content/65 shrink-0 text-sm">{formattedDate}</time>
  </div>
</Tag>
