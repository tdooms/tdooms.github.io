---
import { Image } from 'astro:assets'

interface Props {
  title: string
  description: string
  date: string
  image: ImageMetadata
  alt: string
  link: string
}

const { title, description, date, image, alt, link } = Astro.props
---

<a href={link} class="card block bg-white p-6 shadow-md transition-shadow hover:shadow-lg">
  <div class="flex items-center gap-4">
    <div class="flex-shrink-0">
      <figure class="h-16 w-16">
        <Image src={image} alt={alt} width={64} height={64} class="rounded-full object-cover" />
      </figure>
    </div>
    <div class="flex-grow">
      <h4 class="inline text-xl font-bold text-gray-900">{title}</h4>
      <small class="ml-2 inline text-gray-600">({date})</small>
      <p class="mt-2 text-gray-700">{description}</p>
    </div>
  </div>
</a>
