---
import { Image } from 'astro:assets'

interface Props {
  title: string
  shortTitle?: string
  description: string
  conference: string
  link: string
  external?: boolean
  image?: ImageMetadata
  labels?: string[]
}

const {
  title,
  shortTitle,
  description,
  conference,
  link,
  external = false,
  image,
  labels = [],
} = Astro.props
---

<a
  href={link}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="group bg-base-100 ring-base-300/60 flex h-full flex-col overflow-hidden rounded-xl shadow-sm ring-1 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
>
  <div class="bg-primary/40 h-1"></div>
  {
    image && (
      <figure class="bg-base-200 relative aspect-[5/3] overflow-hidden">
        <Image
          src={image}
          alt={title}
          layout="none"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </figure>
    )
  }
  <div class="flex flex-1 flex-col gap-2 p-4">
    <div
      class="text-base-content/70 flex items-center gap-2 text-xs font-semibold tracking-wider uppercase"
    >
      <span>{conference}</span>
      {
        labels.map((label) => (
          <span class="bg-base-200 text-base-content/75 px-1.5 py-0.5 text-[10px] font-medium tracking-wide normal-case">
            {label}
          </span>
        ))
      }
    </div>
    <h3 class="text-base-content text-base font-bold">{shortTitle ?? title}</h3>
    <p class="text-base-content/75 text-sm leading-snug">{description}</p>
  </div>
</a>
