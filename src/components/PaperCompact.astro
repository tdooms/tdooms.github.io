---
import { Image } from 'astro:assets'

interface Props {
  title: string
  shortTitle?: string | undefined
  description: string
  conference: string
  link: string
  external?: boolean | undefined
  image?: ImageMetadata | undefined
  labels?: string[] | undefined
}

const {
  title,
  shortTitle,
  description,
  conference,
  link,
  external = false,
  image,
  labels = [],
} = Astro.props
---

<a
  href={link}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="card card-border group bg-base-100 border-base-300/60 h-full overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
>
  <div class="bg-primary/40 h-1"></div>
  {
    image && (
      <figure class="bg-base-200 relative aspect-[5/3] overflow-hidden">
        {/* Sized to the card (≈350px wide, 2× for retina) — see Blog.astro;
            unsized `layout="none"` ships the original asset at full weight. */}
        <Image
          src={image}
          alt={title}
          layout="none"
          width={700}
          height={420}
          quality={60}
          class="absolute inset-0 h-full w-full transform-gpu object-cover transition-transform duration-500 [backface-visibility:hidden] group-hover:scale-105"
        />
      </figure>
    )
  }
  <div class="card-body flex-1 gap-2 p-4">
    <div
      class="text-base-content/70 flex items-center gap-2 text-xs font-semibold tracking-wider uppercase"
    >
      <span>{conference}</span>
      {
        labels.map((label) => (
          <span class="badge badge-ghost badge-sm text-[10px] font-medium tracking-wide normal-case">
            {label}
          </span>
        ))
      }
    </div>
    <h3 class="card-title text-base">{shortTitle ?? title}</h3>
    <p class="text-base-content/75 text-sm leading-snug">{description}</p>
  </div>
</a>
