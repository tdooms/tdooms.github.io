---
import { Icon } from 'astro-icon/components'

interface Props {
  paper?: string
  code?: string
  models?: string
  video?: string
  slides?: string
  news?: string
}

const { paper, code, models, video, slides, news } = Astro.props

const resources = [
  { url: paper, icon: 'fa6-regular:file', label: 'Paper' },
  { url: code, icon: 'fa6-solid:code', label: 'Code' },
  { url: models, icon: 'fa6-solid:database', label: 'Models' },
  { url: video, icon: 'fa6-solid:video', label: 'Video' },
  { url: slides, icon: 'fa6-solid:chalkboard', label: 'Slides' },
  { url: news, icon: 'fa6-solid:newspaper', label: 'News' },
].flatMap((r) => (r.url ? [{ ...r, url: r.url, external: !r.url.startsWith('/') }] : []))
---

<div class="flex flex-wrap items-center gap-2">
  {
    resources.map((resource) => (
      <a
        href={resource.url}
        target={resource.external ? '_blank' : undefined}
        rel={resource.external ? 'noopener noreferrer' : undefined}
        class="hover:bg-primary/5 hover:text-primary hover:ring-primary/30 bg-base-100 text-base-content/85 ring-base-300/60 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-medium shadow-sm ring-1 transition-all hover:-translate-y-0.5 hover:shadow-md"
      >
        <Icon name={resource.icon} />
        <span>{resource.label}</span>
      </a>
    ))
  }
</div>
