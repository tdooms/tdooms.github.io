---
import '../assets/app.css'
import 'katex/dist/katex.min.css'
import { ClientRouter } from 'astro:transitions'
import { Font } from 'astro:assets'
import Navbar from '../components/Navbar.astro'
import profileImg from '../assets/profile/main.jpg'

interface Props {
  title?: string | undefined
  description?: string | undefined
  // App-style pages (e.g. /bae) want the full viewport instead of the centered
  // max-w-1100 column. ``bleed`` swaps the wrapping ``<main>`` for a flex
  // column that fills the viewport below the shared Navbar so embedded chrome
  // can use ``flex-1 min-h-0`` and ``h-full`` against a real height.
  bleed?: boolean
}

const { title, description, bleed = false } = Astro.props

const SITE_NAME = 'Thomas Dooms'
const SITE_DESCRIPTION =
  'Thomas Dooms — PhD researcher in compositional interpretability of neural networks.'
const TWITTER_HANDLE = '@thomasdooms'

const pageTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME
const pageDescription = description ?? SITE_DESCRIPTION
const canonical = new URL(Astro.url.pathname, Astro.site).toString()
const ogImage = new URL(profileImg.src, Astro.site).toString()
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <Font cssVariable="--font-fira-sans" preload={[{ weight: 400 }, { weight: 700 }]} />
    <Font cssVariable="--font-fira-code" />

    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:creator" content={TWITTER_HANDLE} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google tag (gtag.js), loaded after the page has had a chance to paint. -->
    <script is:inline>
      window.dataLayer = []
      function gtag() {
        dataLayer.push(arguments)
      }

      function loadAnalytics() {
        const script = document.createElement('script')
        script.async = true
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-7H9E0Y121Q'
        document.head.appendChild(script)
        gtag('js', new Date())
        gtag('config', 'G-7H9E0Y121Q')
      }

      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadAnalytics, { timeout: 2000 })
      } else {
        window.addEventListener('load', loadAnalytics, { once: true })
      }
    </script>

    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main-content"
      class="focus:bg-primary focus:text-primary-content sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:px-4 focus:py-2"
    >
      Skip to content
    </a>

    {
      /* Site Navbar only on regular pages. Bleed (app-style) pages — currently
         just /bae — own their entire top chrome via the embedded navbar (the
         bae InfoBar, which carries home + breadcrumb + stats + search). Two
         top bars would be redundant and the lower one's search would clip. */
      !bleed && <Navbar />
    }

    {
      bleed ? (
        <div id="main-content" class="flex h-dvh flex-col overflow-hidden">
          <slot />
        </div>
      ) : (
        <main id="main-content" class="mx-auto w-full max-w-[1100px] px-4 pb-20">
          <slot />
        </main>
      )
    }
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }

  /* Hide scrollbar but keep scroll functionality. Stops layout jumping between
     short and long pages when navigating. */
  html {
    scrollbar-width: none;
  }
  html::-webkit-scrollbar {
    display: none;
  }
</style>
