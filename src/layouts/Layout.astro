---
import '../assets/app.css'
import 'katex/dist/katex.min.css'
import { ClientRouter } from 'astro:transitions'
import { Font } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import profileImg from '../assets/profile.jpg'

interface Props {
  title?: string
  description?: string
  back?: boolean
}

const { title, description, back = false } = Astro.props

const SITE_NAME = 'Thomas Dooms'
const SITE_DESCRIPTION =
  'Thomas Dooms — PhD researcher in compositional interpretability of neural networks.'
const TWITTER_HANDLE = '@thomasdooms'

const pageTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME
const pageDescription = description ?? SITE_DESCRIPTION
const canonical = new URL(Astro.url.pathname, Astro.site).toString()
const ogImage = new URL(profileImg.src, Astro.site).toString()
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <Font cssVariable="--font-fira-sans" preload />
    <Font cssVariable="--font-fira-code" />

    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:creator" content={TWITTER_HANDLE} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-7H9E0Y121Q"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag('js', new Date())

      gtag('config', 'G-7H9E0Y121Q')
    </script>

    <ClientRouter />
  </head>
  <body>
    <a
      href="#main-content"
      class="focus:bg-primary sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <label
      class="swap swap-rotate text-base-content/65 hover:text-base-content fixed top-4 right-4 z-40 transition-colors"
      aria-label="Toggle dark mode"
    >
      <input type="checkbox" class="theme-controller" value="dark" />
      <Icon name="fa6-solid:sun" class="swap-off h-5 w-5" />
      <Icon name="fa6-solid:moon" class="swap-on h-5 w-5" />
    </label>

    <main id="main-content" class="mx-auto max-w-[1100px] px-4 pt-6 pb-20">
      {
        back && (
          <a
            href="/"
            aria-label="Back to home"
            class="text-base-content/65 ring-base-300/60 hover:text-base-content hover:ring-base-300 mb-6 inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 transition-all hover:-translate-x-0.5"
          >
            <Icon name="fa6-solid:arrow-left" class="text-sm" />
          </a>
        )
      }
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  /* Hide scrollbar but keep scroll functionality. Stops layout jumping between
     short and long pages when navigating. */
  html {
    scrollbar-width: none;
  }
  html::-webkit-scrollbar {
    display: none;
  }
</style>
