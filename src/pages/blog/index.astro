---
import Layout from '../../layouts/Layout.astro'
import Blog from '../../components/Blog.astro'
import { getCollection } from 'astro:content'

const blogs = await getCollection('blogs')
const sorted = blogs.sort((a, b) => b.data.date.localeCompare(a.data.date))
---

<Layout
  back
  title="Blog"
  description="Informal posts on interpretability, machine learning, and other curiosities."
>
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      sorted.map((blog) => (
        <Blog
          title={blog.data.title}
          date={blog.data.date}
          image={blog.data.image}
          link={blog.data.external ?? `/blog/${blog.id}`}
          external={!!blog.data.external}
        />
      ))
    }
  </div>
</Layout>
