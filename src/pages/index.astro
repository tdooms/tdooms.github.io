---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import profileImg from '../assets/profile/main.jpg'
import skiImg from '../assets/profile/ski.jpg'
import oldImg from '../assets/profile/old.jpg'
import youngImg from '../assets/profile/young.jpg'
import goodfireSvg from '../assets/goodfire.svg?raw'
import News from '../components/News.astro'
import PaperCompact from '../components/PaperCompact.astro'
import Blog from '../components/Blog.astro'
import { getCollection } from 'astro:content'

const papers = (await getCollection('papers')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
)
const blogs = (await getCollection('blogs')).sort((a, b) => b.data.date.localeCompare(a.data.date))
const news = (await getCollection('news')).sort((a, b) => b.data.date.localeCompare(a.data.date))

// `external` gates target="_blank" (site convention: explicit flag, never a
// protocol heuristic). Email and Resume stay in-tab.
const contactLinks = [
  {
    icon: 'fa6-solid:envelope',
    label: 'Email',
    href: 'mailto:doomsthomas@gmail.com',
    external: false,
  },
  {
    icon: 'fa6-brands:x-twitter',
    label: 'Twitter',
    href: 'https://x.com/thomasdooms',
    external: true,
  },
  { icon: 'fa6-brands:github', label: 'GitHub', href: 'https://github.com/tdooms', external: true },
  {
    icon: 'fa6-brands:linkedin',
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/thomas-dooms-5518a4169/',
    external: true,
  },
  { icon: 'fa6-solid:calendar', label: 'Meet', href: 'https://cal.com/tdooms', external: true },
  { icon: 'fa6-solid:file-lines', label: 'Resume', href: '/resume', external: false },
]
---

<Layout>
  <!-- Hero -->
  <section class="grid grid-cols-1 items-stretch gap-10 lg:grid-cols-[260px_1fr]">
    <!-- Profile -->
    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <Image
        src={profileImg}
        alt="Thomas Dooms"
        class="ring-base-300 h-40 w-40 rounded-2xl object-cover shadow-md ring-1"
        width={320}
        height={320}
        loading="eager"
      />
      <h1 class="text-base-content mt-5 text-4xl font-bold tracking-tight">Thomas Dooms</h1>
      <p class="text-base-content/70 mt-2 text-sm font-semibold tracking-widest uppercase">
        Member of Technical Staff <a
          href="https://www.goodfire.ai/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-primary text-base-content/85 inline-flex items-baseline gap-1.5 whitespace-nowrap transition-colors"
        >
          Goodfire
          <span
            class="text-primary inline-block h-3.5 w-[0.72rem] translate-y-px [&>svg]:h-full [&>svg]:w-full"
            set:html={goodfireSvg}
          />
        </a>
      </p>
      <p class="text-base-content/70 text-sm">PhD in interpretable AI</p>

      <div
        class="text-base-content/75 mt-5 grid grid-cols-3 justify-items-center gap-x-4 gap-y-2 text-sm lg:justify-items-start"
      >
        {
          contactLinks.map(({ icon, label, href, external }) => (
            <a
              href={href}
              class="hover:text-primary inline-flex items-center gap-1.5 transition-colors"
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              <Icon name={icon} />
              <span>{label}</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Bio -->
    <div class="prose flex max-w-none flex-col justify-between [&>p]:my-0">
      <p>
        Hey, I'm Thomas. I work on the life sciences team at <a
          href="https://www.goodfire.ai/"
          target="_blank"
          rel="noopener noreferrer"
          class="hl">Goodfire</a
        >, doing interpretability: the <span
          class="tooltip tooltip-bottom cursor-help align-baseline [--tt-bg:var(--color-base-100)]"
          ><span
            tabindex="0"
            class="hl focus-visible:outline-primary rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >science</span
          ><span class="tooltip-content not-prose text-base-content p-2">read dark art</span></span
        > of understanding what AI models have learned. These models outperform human experts in tasks
        ranging from prose to games without ever being told what or how. In short, I aim to answer:
      </p>

      <p class="italic">What do AI models know that we don't, and how do we pry it out?</p>

      <p>
        Models think in numbers and geometries; we think in concepts and compositions. My research
        interfaces the two by treating networks as compositional systems whose parts interact and
        recombine, reading their geometric structure directly instead of shoehorning it into
        simplistic features. My PhD built the mathematical foundations. Now I'm pointing them at
        open problems in the life sciences.
      </p>

      <p>
        When I'm not researching, you'll find me on a long bike ride, <span
          class="tooltip tooltip-top cursor-help align-baseline [--tt-bg:var(--color-base-100)]"
          ><span
            tabindex="0"
            class="hl focus-visible:outline-primary rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >gaming</span
          ><span class="tooltip-content not-prose text-base-content p-2">
            <span class="flex gap-2">
              {/* Chronological: childhood photo first, recent photo second. */}
              <Image
                src={youngImg}
                alt=""
                class="aspect-square w-48 rounded-md object-cover"
                width={320}
                height={320}
                loading="lazy"
              />
              <Image
                src={oldImg}
                alt=""
                class="aspect-square w-48 rounded-md object-cover"
                width={320}
                height={320}
                loading="lazy"
              />
            </span>
            <span class="text-base-content/70 mt-2 block text-left text-xs leading-relaxed">
              doing the computer stuff since ...
            </span>
          </span></span
        > with friends, skiing, wearing shorts, or some
        <span class="tooltip tooltip-top cursor-help align-baseline [--tt-bg:var(--color-base-100)]"
          ><span
            tabindex="0"
            class="hl focus-visible:outline-primary rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >combination</span
          ><span class="tooltip-content not-prose text-base-content p-2">
            <Image
              src={skiImg}
              alt=""
              class="aspect-square w-48 rounded-md object-cover"
              width={320}
              height={320}
              loading="lazy"
            />
            <span class="text-base-content/70 mt-2 block text-left text-xs leading-relaxed">
              It's a sunny day!
            </span>
          </span></span
        >. I used to play a lot of Diablo 3, reaching <span
          class="tooltip tooltip-top cursor-help align-baseline [--tt-bg:var(--color-base-100)]"
          ><span
            tabindex="0"
            class="hl focus-visible:outline-primary rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >top-1</span
          ><span class="tooltip-content not-prose text-base-content p-2">suck it Elon</span></span
        > on the grift leaderboards.
      </p>
    </div>
  </section>

  <!-- Papers -->
  <section class="mt-14">
    <h2 class="text-base-content mb-6 text-2xl font-bold">
      Papers<span class="text-primary">.</span>
    </h2>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {papers.map((paper) => <PaperCompact {...paper.data} />)}
    </div>
  </section>

  <!-- News -->
  <section class="mt-14">
    <h2 class="text-base-content mb-6 text-2xl font-bold">
      News<span class="text-primary">.</span>
    </h2>
    <div class="space-y-2">
      {news.map((item) => <News {...item.data} />)}
    </div>
  </section>

  <!-- Blog -->
  {
    blogs.length > 0 && (
      <section class="mt-14">
        <h2 class="text-base-content mb-6 text-2xl font-bold">
          Blog<span class="text-primary">.</span>
        </h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {blogs.map((blog) => (
            <Blog
              title={blog.data.title}
              date={blog.data.date}
              image={blog.data.image}
              link={blog.data.external ?? `/blog/${blog.id}`}
              external={!!blog.data.external}
            />
          ))}
        </div>
      </section>
    )
  }
</Layout>
