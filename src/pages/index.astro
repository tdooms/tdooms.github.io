---
import Layout from '../layouts/Layout.astro'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import profileImg from '../assets/profile.jpg'
import goodfireSvg from '../assets/goodfire.svg?raw'
import News from '../components/News.astro'
import PaperCompact from '../components/PaperCompact.astro'
import Blog from '../components/Blog.astro'
import { getCollection } from 'astro:content'

const papers = (await getCollection('papers')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
)
const blogs = (await getCollection('blogs')).sort((a, b) => b.data.date.localeCompare(a.data.date))
const news = (await getCollection('news')).sort((a, b) => b.data.date.localeCompare(a.data.date))

const contactLinks = [
  { icon: 'fa6-solid:envelope', label: 'Email', href: 'mailto:doomsthomas@gmail.com' },
  { icon: 'fa6-brands:x-twitter', label: 'Twitter', href: 'https://x.com/thomasdooms' },
  { icon: 'fa6-brands:github', label: 'GitHub', href: 'https://github.com/tdooms' },
  {
    icon: 'fa6-brands:linkedin',
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/thomas-dooms-5518a4169/',
  },
  { icon: 'fa6-solid:calendar', label: 'Meet', href: 'https://cal.com/tdooms' },
  { icon: 'fa6-solid:file-lines', label: 'Resume', href: '/resume' },
]
---

<Layout>
  <!-- Hero -->
  <section class="grid grid-cols-1 items-stretch gap-10 lg:grid-cols-[260px_1fr]">
    <!-- Profile -->
    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <Image
        src={profileImg}
        alt="Thomas Dooms"
        class="ring-base-300 h-40 w-40 rounded-2xl object-cover shadow-md ring-1"
        width={320}
        height={320}
        loading="eager"
        fetchpriority="high"
      />
      <h1 class="text-base-content mt-5 text-4xl font-bold tracking-tight">Thomas Dooms</h1>
      <p class="text-base-content/70 mt-2 text-sm font-semibold tracking-widest uppercase">
        Member of Technical Staff <a
          href="https://www.goodfire.ai/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-primary text-base-content/85 inline-flex items-baseline gap-1.5 whitespace-nowrap transition-colors"
        >
          Goodfire
          <span
            class="text-primary inline-block h-3.5 w-[0.72rem] translate-y-px [&>svg]:h-full [&>svg]:w-full"
            set:html={goodfireSvg}
          />
        </a>
      </p>
      <p class="text-base-content/70 text-sm">PhD in interpretability</p>

      <div
        class="text-base-content/75 mt-5 flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm lg:justify-start"
      >
        {
          contactLinks.map(({ icon, label, href }) => (
            <a
              href={href}
              class="hover:text-primary inline-flex items-center gap-1.5 transition-colors"
              target={href.startsWith('http') ? '_blank' : undefined}
              rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              <Icon name={icon} />
              <span>{label}</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Bio -->
    <div class="prose prose-gray flex max-w-none flex-col justify-between [&>p]:my-0">
      <p>
        Hi, I'm Thomas! I'm a PhD student working on <a
          href="https://compinterp.github.io"
          target="_blank"
          rel="noopener noreferrer"
          class="hl">compositional interpretability</a
        >. I'm interested in understanding how neural networks encode complex behaviours and
        knowledge.
      </p>

      <p>
        Modern deep networks are astonishingly intricate and difficult to disentangle. I argue that
        we should embrace this <span class="hl">complexity</span> rather than shoehorn them into simplistic
        feature sets, flattening the very structures we hope to understand.
      </p>

      <p>
        My research treats a model's weights as a <span class="hl">compositional system</span> whose parts
        interact and recombine. By developing flexible, formally grounded tools for compositional analysis,
        I aim to reveal how rich mechanisms and representations arise and how we can reason about them.
      </p>

      <p>
        Outside of work, I love to go on long bike rides, game with friends, go skiing and wear
        shorts. I used to play a lot of Diablo 3, achieving <span
          class="tooltip"
          data-tip="Suck it Elon"><span class="hl">top-1</span></span
        > in grift leaderboards at some point.
      </p>
    </div>
  </section>

  <!-- Papers -->
  <section class="mt-14">
    <h2 class="text-base-content mb-6 text-2xl font-bold">
      Papers<span class="text-primary">.</span>
    </h2>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {papers.map((paper) => <PaperCompact {...paper.data} />)}
    </div>
  </section>

  <!-- News -->
  <section class="mt-14">
    <h2 class="text-base-content mb-6 text-2xl font-bold">
      News<span class="text-primary">.</span>
    </h2>
    <div class="space-y-2">
      {news.map((item) => <News {...item.data} />)}
    </div>
  </section>

  <!-- Blog -->
  {
    blogs.length > 0 && (
      <section class="mt-14">
        <h2 class="text-base-content mb-6 text-2xl font-bold">
          Blog<span class="text-primary">.</span>
        </h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {blogs.map((blog) => (
            <Blog
              title={blog.data.title}
              date={blog.data.date}
              image={blog.data.image}
              link={blog.data.external ?? `/blog/${blog.id}`}
              external={!!blog.data.external}
            />
          ))}
        </div>
      </section>
    )
  }
</Layout>
