---
import { getCollection, getEntry, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Authors from '../../components/Authors.astro'
import Resources from '../../components/Resources.astro'
import Cite from '../../components/Cite.astro'
import EntryNav from '../../components/EntryNav.astro'

export async function getStaticPaths() {
  const papers = await getCollection('papers')
  const sorted = papers.slice().sort((a, b) => b.data.date.localeCompare(a.data.date))
  const titleOf = (p: (typeof sorted)[number]) => p.data.shortTitle ?? p.data.title
  return papers.map((paper) => {
    const idx = sorted.findIndex((p) => p.id === paper.id)
    const prev =
      idx > 0 ? { href: sorted[idx - 1]!.data.link, title: titleOf(sorted[idx - 1]!) } : null
    const next =
      idx < sorted.length - 1
        ? { href: sorted[idx + 1]!.data.link, title: titleOf(sorted[idx + 1]!) }
        : null
    return { params: { id: paper.id }, props: { paper, prev, next } }
  })
}

const { paper, prev, next } = Astro.props
const body = await getEntry('papersContent', paper.id)
if (!body) {
  throw new Error(
    `Missing MDX body for paper "${paper.id}". Expected src/content/papers/${paper.id}/content.mdx`,
  )
}
const { Content } = await render(body)
---

<Layout title={paper.data.shortTitle ?? paper.data.title} description={paper.data.description}>
  <h1 class="mb-2 text-4xl font-bold">{paper.data.shortTitle ?? paper.data.title}</h1>
  <Authors authors={paper.data.authors} />
  <div class="mt-6"></div>

  <Resources
    paper={paper.data.paper}
    code={paper.data.code}
    demo={paper.data.demo}
    models={paper.data.models}
    video={paper.data.video}
    slides={paper.data.slides}
    news={paper.data.news}
  />

  <div class="prose prose-lg mt-6 max-w-none">
    <Content />
  </div>

  <div class="pt-6"></div>
  {paper.data.bibtex && <Cite bib={paper.data.bibtex} />}

  <EntryNav prev={prev} next={next} />
</Layout>
